<!DOCTYPE html>
<html lang="id">

<head>
    <%- include('partials/head', { title: 'Student Dashboard' }) %>
</head>

<body>

    <%- include('partials/nav', { user }) %>

    <div class="container">

        <div class="page-head" style="margin-top:32px;">

            <div>

                <div class="hero-eyebrow">
                    Student Dashboard
                </div>

                <h1>
                    Halo, <%= user.username %> 👋
                </h1>

                <p>
                    Selamat datang kembali di TutorHub.
                    Temukan tutor terbaik dan mulai perjalanan belajarmu.
                </p>

            </div>

        </div>


        <div class="menu-grid">

            <a class="menu-card" href="/services">

                <h3>
                    Find a Tutor
                </h3>

                <p>
                    Jelajahi layanan tutoring yang tersedia
                    dan temukan tutor yang sesuai dengan kebutuhanmu.
                </p>

            </a>


            <a class="menu-card" href="/category">

                <h3>
                    Browse Categories
                </h3>

                <p>
                    Cari layanan tutoring berdasarkan
                    kategori atau bidang pembelajaran.
                </p>

            </a>


            <a class="menu-card" href="/student/bookings">

                <h3>
                    My Bookings
                </h3>

                <p>
                    Lihat dan pantau status booking
                    tutoring yang sudah kamu lakukan.
                </p>

            </a>

        </div>


        <div class="card" style="margin-top:32px;">

            <h2>
                Start Your Learning Journey 🚀
            </h2>

            <p>
                Belajar menjadi lebih mudah bersama tutor
                yang sesuai dengan kebutuhanmu.
                Temukan layanan tutoring sekarang dan mulai belajar.
            </p>

            <a 
                class="btn" 
                href="/services"
            >
                Explore Tutoring Services
            </a>

        </div>

    </div>

</body>
</html>