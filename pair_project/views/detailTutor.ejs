<!DOCTYPE html>
<html lang="id">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Detail Layanan - Bimbel</title>
    <!-- Bootstrap 5 CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>

<body class="bg-light">

    <!-- Navigation Bar (Opsional jika ingin disamakan) -->
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark shadow-sm">
        <div class="container">
            <a class="navbar-brand fw-bold" href="/">BimbelKu</a>
            <div class="collapse navbar-collapse">
                <ul class="navbar-nav ms-auto">
                    <li class="nav-item"><a class="nav-link" href="/">Home</a></li>
                    <li class="nav-item"><a class="nav-link" href="/category">Tutor List</a></li>
                    <li class="nav-item"><a class="nav-link" href="/mybookings">My Bookings</a></li>
                </ul>
            </div>
        </div>
    </nav>

    <div class="container my-5">
        <!-- Tombol Kembali -->
        <div class="mb-3">
            <a href="/category" class="btn btn-outline-secondary btn-sm px-3">← Kembali ke Daftar</a>
        </div>

        <!-- Header Detail -->
        <div class="mb-4">
            <h2 class="fw-bold text-dark">
                <%= tutor.name %> - <%= tutor.Category ? tutor.Category.name : '-' %>
            </h2>
            <p class="text-muted">Informasi lengkap mengenai materi dan pengajar.</p>
        </div>

        <!-- Layout Flexbox (Dua Kolom) -->
        <div class="row g-4 align-items-start">
            <!-- Kolom Kiri: Gambar dengan Border Radius -->
            <div class="col-lg-6">
                <div class="card shadow-sm border-0 overflow-hidden">
                    <img src="<%= tutor.imageUrl || 'https://images.unsplash.com/photo-1509062522246-3755977927d7?q=80&w=800&auto=format&fit=crop' %>"
                        alt="Gambar Layanan" class="img-fluid w-100"
                        style="border-radius: 12px; object-fit: cover; height: 400px;">
                </div>
            </div>

            <!-- Kolom Kanan: Informasi & Tombol Pesan -->
            <div class="col-lg-6">
                <div class="card shadow-sm border-0 p-4">
                    <h4 class="fw-bold mb-3 text-primary">Deskripsi Materi</h4>
                    <p class="text-secondary" style="white-space: pre-line;">
                        <%= tutor.description %>
                    </p>

                    <hr class="my-4">

                    <div class="mb-3">
                        <span class="text-muted d-block small">Tarif per Sesi</span>
                        <h3 class="text-success fw-bold">Rp <%= Number(tutor.price).toLocaleString('id-ID') %>
                        </h3>
                    </div>

                    <div class="mb-4">
                        <span class="text-muted d-block small">Informasi Tutor</span>
                        <h5 class="fw-semibold mb-1">
                            <%= tutor.User && tutor.User.UserProfile ? tutor.User.UserProfile.fullname : (tutor.User ?
                                tutor.User.username : '-' ) %>
                        </h5>
                        <p class="text-secondary mb-0">📞 <%= tutor.User && tutor.User.UserProfile ?
                                tutor.User.UserProfile.phoneNumber : '-' %>
                        </p>
                    </div>

                    <!-- Tombol Pesan / Booking dengan Form POST sesuai rute aplikasi Anda -->
                    <form action="/booking/<%= tutor.id %>" method="POST">
                        <button type="submit" class="btn btn-primary btn-lg w-100 py-3 fw-bold">Booking
                            Sekarang</button>
                    </form>
                </div>
            </div>
        </div>
    </div>

    <!-- Bootstrap 5 JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>

</html>