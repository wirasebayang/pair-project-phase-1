<!DOCTYPE html>
<html lang="id">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Form Layanan - BimbelKu</title>
    <!-- Bootstrap 5 CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>

<body class="bg-light">

    <!-- Navigation Bar (Opsional) -->
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark shadow-sm">
        <div class="container">
            <a class="navbar-brand fw-bold" href="/">BimbelKu</a>
            <div class="collapse navbar-collapse">
                <ul class="navbar-nav ms-auto">
                    <li class="nav-item"><a class="nav-link" href="/">Home</a></li>
                    <li class="nav-item"><a class="nav-link" href="/category">Tutor List</a></li>
                    <li class="nav-item"><a class="nav-link" href="/mybookings">My Bookings</a></li>
                </ul>
            </div>
        </div>
    </nav>

    <div class="container my-5">
        <div class="row justify-content-center">
            <div class="col-lg-7">

                <div class="card shadow-sm border-0 p-4 p-md-5">
                    <h3 class="fw-bold mb-4 text-center">Tambah Layanan Baru</h3>

                    <!-- Validasi Visual (Pesan Error Dinamis jika ada error dari backend) -->
                    <% if (typeof error !=='undefined' && error) { %>
                        <div class="alert alert-danger d-flex align-items-center mb-4" role="alert">
                            <div>
                                <%= error %>
                            </div>
                        </div>
                        <% } %>

                            <!-- Form Vertikal dengan Method POST dan Action yang sesuai -->
                            <form action="/services/add" method="POST">

                                <div class="mb-3">
                                    <label for="name" class="form-label fw-semibold">Nama Layanan</label>
                                    <input type="text" class="form-control" id="name" name="name"
                                        placeholder="Contoh: Privat Fisika Dasar" required>
                                </div>

                                <div class="mb-3">
                                    <label for="CategoryId" class="form-label fw-semibold">Kategori</label>
                                    <select class="form-select" id="CategoryId" name="CategoryId" required>
                                        <option value="" disabled selected>Pilih kategori...</option>
                                        <% if (categories && categories.length> 0) { %>
                                            <% categories.forEach(cat=> { %>
                                                <option value="<%= cat.id %>">
                                                    <%= cat.name %>
                                                </option>
                                                <% }) %>
                                                    <% } %>
                                    </select>
                                </div>

                                <div class="mb-3">
                                    <label for="price" class="form-label fw-semibold">Harga (Rp)</label>
                                    <input type="number" class="form-control" id="price" name="price"
                                        placeholder="Contoh: 100000" required>
                                </div>

                                <div class="mb-3">
                                    <label for="description" class="form-label fw-semibold">Deskripsi</label>
                                    <textarea class="form-control" id="description" name="description" rows="4"
                                        style="white-space: pre-line;" placeholder="Masukkan detail materi..."
                                        required></textarea>
                                </div>

                                <div class="mb-4">
                                    <label for="imageUrl" class="form-label fw-semibold">URL Gambar / File</label>
                                    <input type="text" class="form-control" id="imageUrl" name="imgUrl"
                                        placeholder="https://example.com/image.jpg">
                                </div>

                                <div class="d-flex gap-2">
                                    <button type="submit" class="btn btn-success px-4 py-2 fw-semibold">Submit</button>
                                    <a href="/category" class="btn btn-outline-secondary px-4 py-2">Back</a>
                                </div>

                            </form>
                </div>

            </div>
        </div>
    </div>

    <!-- Bootstrap 5 JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>

</html>