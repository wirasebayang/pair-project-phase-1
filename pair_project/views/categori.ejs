<!DOCTYPE html>
<html lang="id">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Daftar Layanan - BimbelKu</title>
    <!-- Bootstrap 5 CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>

<body class="bg-light">

    <!-- Navigation Bar -->
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark shadow-sm">
        <div class="container">
            <a class="navbar-brand fw-bold" href="/">BimbelKu</a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav ms-auto align-items-lg-center">
                    <li class="nav-item"><a class="nav-link" href="/">Home</a></li>
                    <li class="nav-item"><a class="nav-link active" href="/category">Tutor List</a></li>
                    <li class="nav-item"><a class="nav-link" href="/mybookings">My Bookings</a></li>
                    <li class="nav-item">
                        <a class="nav-link btn btn-primary text-white px-3 ms-lg-2 mt-2 mt-lg-0"
                            href="/services/add">Add Service</a>
                    </li>
                </ul>
            </div>
        </div>
    </nav>

    <!-- Main Container -->
    <div class="container my-5">

        <!-- Header & Judul Halaman -->
        <div class="d-flex justify-content-between align-items-center mb-4">
            <div>
                <h2 class="fw-bold mb-1">Daftar Layanan Bimbingan</h2>
                <p class="text-muted mb-0">Pilih kategori dan layanan tutor yang tersedia sesuai kebutuhan Anda.</p>
            </div>
        </div>

        <!-- Filter Kategori (Dinamis dan Tetap Lengkap) -->
        <div class="mb-4">
            <h5 class="mb-3 fw-bold text-secondary" style="font-size: 1rem;">Kategori Layanan</h5>
            <div class="d-flex flex-wrap gap-2">
                <!-- Tombol All untuk mereset filter -->
                <a href="/category"
                    class="btn <%= !selectedCategory ? 'btn-dark' : 'btn-outline-secondary' %> btn-sm px-4">All</a>

                <% if (category && category.length> 0) { %>
                    <% category.forEach(cat=> { %>
                        <!-- Mengirim query parameter ?categoryId=... dan memberikan efek warna aktif jika dipilih -->
                        <a href="/category?categoryId=<%= cat.id %>"
                            class="btn <%= selectedCategory == cat.id ? 'btn-dark' : 'btn-outline-secondary' %> btn-sm px-4">
                            <%= cat.name %>
                        </a>
                        <% }) %>
                            <% } %>
            </div>
        </div>

        <!-- Tabel Layanan -->
        <div class="card shadow-sm border-0">
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-striped align-middle mb-0">
                        <thead class="table-dark">
                            <tr>
                                <th scope="col" class="py-3 ps-3" style="width: 5%;">No</th>
                                <th scope="col" class="py-3" style="width: 30%;">Nama Layanan</th>
                                <th scope="col" class="py-3" style="width: 20%;">Kategori</th>
                                <th scope="col" class="py-3" style="width: 15%;">Harga</th>
                                <th scope="col" class="py-3" style="width: 15%;">Tutor</th>
                                <th scope="col" class="py-3 text-center" style="width: 15%;">Action</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% let counter=1; let hasData=false; if (category && category.length> 0) {
                                category.forEach(cat => {
                                if (!selectedCategory || selectedCategory == cat.id) {
                                if (cat.TutoringServices && cat.TutoringServices.length > 0) {
                                hasData = true;
                                cat.TutoringServices.forEach((el, i) => {
                                %>
                                <tr>
                                    <td class="ps-3">
                                        <%= counter++ %>
                                    </td>
                                    <td class="fw-semibold">
                                        <%= el.name %>
                                    </td>
                                    <td>
                                        <span class="badge bg-secondary">
                                            <%= cat.name %>
                                        </span>
                                    </td>
                                    <td class="text-success fw-bold">Rp <%= Number(el.price).toLocaleString('id-ID') %>
                                    </td>
                                    <td>
                                        <%= el.User ? el.User.username : '-' %>
                                    </td>
                                    <td class="text-center">
                                        <a href="/tutor/<%= el.id %>"
                                            class="btn btn-sm btn-outline-primary px-2 me-1">See Detail</a>
                                        <form action="/booking/<%= el.id %>" method="POST" class="d-inline">
                                            <button type="submit" class="btn btn-sm btn-primary px-2">Book Now</button>
                                        </form>
                                    </td>
                                </tr>
                                <% }); } } }); } if (!hasData) { %>
                                    <tr>
                                        <td colspan="6" class="text-center text-muted py-4">Belum ada layanan tersedia.
                                        </td>
                                    </tr>
                                    <% } %>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <!-- Bootstrap 5 JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>

</html>