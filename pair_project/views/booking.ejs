<!DOCTYPE html>
<html lang="id">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>My Bookings - Dashboard Siswa</title>
    <!-- Bootstrap 5 CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>

<body class="bg-light">

    <!-- Navigation Bar -->
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark shadow-sm">
        <div class="container">
            <a class="navbar-brand fw-bold" href="/">BimbelKu</a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav ms-auto align-items-lg-center">
                    <li class="nav-item"><a class="nav-link" href="/">Home</a></li>
                    <li class="nav-item"><a class="nav-link" href="/category">Tutor List</a></li>
                    <li class="nav-item"><a class="nav-link active" href="/mybookings">My Bookings</a></li>
                    <li class="nav-item">
                        <a class="nav-link btn btn-primary text-white px-3 ms-lg-2 mt-2 mt-lg-0"
                            href="/services/add">Add Service</a>
                    </li>
                </ul>
            </div>
        </div>
    </nav>

    <!-- Main Container -->
    <div class="container my-5">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <div>
                <h2 class="fw-bold mb-1">Dashboard Booking Saya</h2>
                <p class="text-muted mb-0">Daftar jadwal bimbingan belajar yang telah Anda pesan.</p>
            </div>
            <div>
                <a href="/category" class="btn btn-outline-secondary btn-sm px-3">← Layanan Tutor</a>
            </div>
        </div>

        <!-- Tabel Booking (Eager Loading Data dengan Bootstrap Styling) -->
        <div class="card shadow-sm border-0">
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-striped align-middle mb-0">
                        <thead class="table-dark">
                            <tr>
                                <th scope="col" class="py-3 ps-3" style="width: 10%;">No</th>
                                <th scope="col" class="py-3" style="width: 25%;">Tanggal Booking</th>
                                <th scope="col" class="py-3" style="width: 30%;">Nama Layanan</th>
                                <th scope="col" class="py-3" style="width: 20%;">Nama Tutor</th>
                                <th scope="col" class="py-3 text-center" style="width: 15%;">Status</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% if (bookings && bookings.length> 0) { %>
                                <% bookings.forEach((booking, i)=> { %>
                                    <tr>
                                        <td class="ps-3">
                                            <%= i + 1 %>
                                        </td>
                                        <td>
                                            <%= booking.createdAt ? booking.createdAt.toLocaleDateString('id-ID', {
                                                day: 'numeric' , month: 'long' , year: 'numeric' }) : '-' %>
                                        </td>
                                        <td class="fw-semibold">
                                            <%= booking.TutoringService ? booking.TutoringService.name : '-' %>
                                        </td>
                                        <td>
                                            <%= booking.TutoringService && booking.TutoringService.User ?
                                                booking.TutoringService.User.username : '-' %>
                                        </td>
                                        <td class="text-center">
                                            <% if (booking.status==='Pending' ) { %>
                                                <div class="d-flex justify-content-center align-items-center gap-2">
                                                    <span class="badge bg-warning text-dark px-2 py-1">Pending</span>
                                                    <form action="/booking/confirm/<%= booking.id %>" method="POST"
                                                        class="m-0">
                                                        <button type="submit" class="btn btn-sm btn-success px-2 py-1"
                                                            style="font-size: 11px;">Konfirmasi</button>
                                                    </form>
                                                </div>
                                                <% } else if (booking.status==='Confirmed' ) { %>
                                                    <span class="badge bg-success px-2 py-1">Confirmed</span>
                                                    <% } else { %>
                                                        <span class="badge bg-secondary px-2 py-1">
                                                            <%= booking.status %>
                                                        </span>
                                                        <% } %>
                                        </td>
                                    </tr>
                                    <% }) %>
                                        <% } else { %>
                                            <tr>
                                                <td colspan="5" class="text-center text-muted py-4">Belum ada data
                                                    booking yang tersedia.</td>
                                            </tr>
                                            <% } %>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <!-- Bootstrap 5 JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>

</html>