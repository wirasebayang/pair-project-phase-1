<!DOCTYPE html>
<html lang="id">

<head>
    <%- include('partials/head', { title: category.name }) %>
</head>

<body>

    <%- include('partials/nav', { user }) %>

    <div class="container">

        <div class="page-head" style="margin-top:32px;">

            <div>

                <a 
                    href="/category"
                    style="
                        text-decoration:none;
                        font-size:14px;
                    "
                >
                    ← Back to Categories
                </a>

                <div 
                    class="hero-eyebrow"
                    style="margin-top:18px;"
                >
                    Tutoring Category
                </div>

                <h1>
                    <%= category.name %>
                </h1>

                <p>
                    Temukan layanan tutoring terbaik
                    untuk kategori <strong><%= category.name %></strong>.
                </p>

            </div>

            <% if (user.role === 'tutor') { %>

                <a 
                    class="btn"
                    href="/tutor/services/add"
                >
                    + Tambah Layanan
                </a>

            <% } %>

        </div>


        <% if (services.length === 0) { %>

            <div class="card">

                <h3>
                    Belum ada layanan tersedia
                </h3>

                <p>
                    Saat ini belum ada tutor yang menyediakan
                    layanan untuk kategori <%= category.name %>.
                </p>

                <a 
                    class="btn"
                    href="/services"
                >
                    Lihat Semua Layanan
                </a>

            </div>

        <% } else { %>

            <div 
                style="
                    margin-bottom:24px;
                    color:#666;
                "
            >
                Menampilkan <strong><%= services.length %></strong>
                layanan tutoring dalam kategori
                <strong><%= category.name %></strong>.
            </div>


            <div class="service-grid">

                <% services.forEach(el => { %>

                    <div 
                        class="service-card <%= catColor(el.Category ? el.Category.name : '') %>"
                    >

                        <span 
                            class="tag <%= catColor(el.Category ? el.Category.name : '') %>"
                        >
                            <%= el.Category ? el.Category.name : '-' %>
                        </span>


                        <h3>
                            <%= el.name %>
                        </h3>


                        <div class="service-meta">

                            Tutor:
                            <%= el.User ? el.User.displayName : '-' %>

                        </div>


                        <div class="service-price">

                            <%= el.formattedPrice %>

                        </div>


                        <div class="service-actions">

                            <a 
                                class="btn btn-outline btn-sm"
                                href="/services/<%= el.id %>"
                            >
                                Detail
                            </a>


                            <% if (user.role === 'student') { %>

                                <% if (bookedServiceIds.includes(el.id)) { %>

                                    <button
                                        class="btn btn-sm"
                                        type="button"
                                        disabled
                                    >
                                        Booked
                                    </button>

                                <% } else { %>

                                    <form
                                        class="inline"
                                        action="/student/bookings/<%= el.id %>"
                                        method="post"
                                    >

                                        <button
                                            class="btn btn-sm"
                                            type="submit"
                                        >
                                            Booking
                                        </button>

                                    </form>

                                <% } %>

                            <% } %>


                            <% if (
                                user.role === 'tutor' &&
                                el.UserId === user.id
                            ) { %>

                                <a 
                                    class="btn btn-outline btn-sm"
                                    href="/tutor/services/edit/<%= el.id %>"
                                >
                                    Edit
                                </a>


                                <form 
                                    class="inline"
                                    action="/tutor/services/delete/<%= el.id %>"
                                    method="post"
                                >

                                    <button 
                                        class="btn btn-danger btn-sm"
                                        type="submit"
                                        onclick="return confirm('Yakin hapus service ini?')"
                                    >
                                        Hapus
                                    </button>

                                </form>

                            <% } %>

                        </div>

                    </div>

                <% }) %>

            </div>

        <% } %>

    </div>

</body>

</html>