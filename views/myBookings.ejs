<!DOCTYPE html>
<html lang="id">
<head>
    <%- include('partials/head', { title: 'Booking Saya' }) %>
</head>
<body>
    <%- include('partials/nav', { user }) %>

    <div class="container">
        <div class="page-head" style="margin-top:32px;">
            <div>
                <div class="hero-eyebrow">Student</div>
                <h1>Booking Saya</h1>
            </div>
        </div>

        <div class="table-wrap">
            <table class="ledger">
                <tr>
                    <th style="width:48px;">No</th>
                    <th>Layanan</th>
                    <th>Tanggal Booking</th>
                    <th>Status</th>
                    <th>Aksi</th>
                </tr>
                <% if (bookings.length === 0) { %>
                    <tr class="empty-row"><td colspan="5">Kamu belum memesan les apa pun. <a href="/services">Cari layanan &rarr;</a></td></tr>
                <% } %>
                <% bookings.forEach((el, i) => { %>
                <tr>
                    <td class="mono"><%= i + 1 %></td>
                    <td><%= el.Service ? el.Service.name : '-' %></td>
                    <td class="mono"><%= new Date(el.bookingDate).toLocaleDateString('id-ID') %></td>
                    <td><span class="badge <%= statusColor(el.status) %>"><%= el.status %></span></td>
                    <td>
                        <% if (el.canBeCancelled()) { %>
                            <form action="/student/bookings/<%= el.id %>/cancel" method="post">
                                <button class="btn btn-danger btn-sm" type="submit">Batalkan</button>
                            </form>
                        <% } else if (el.status === 'completed') { %>
                            <button class="btn btn-danger btn-sm" type="button" disabled>Batalkan</button>
                        <% } else { %>
                            -
                        <% } %>
                    </td>
                </tr>
                <% }) %>
            </table>
        </div>
    </div>
</body>
</html>
