<!DOCTYPE html>
<html lang="id">
<head>
    <%- include('partials/head', { title: 'Booking Masuk' }) %>
</head>
<body>
    <%- include('partials/nav', { user }) %>

    <div class="container">
        <div class="page-head" style="margin-top:32px;">
            <div>
                <div class="hero-eyebrow">Tutor</div>
                <h1>Booking Masuk</h1>
            </div>
        </div>

        <div class="table-wrap">
            <table class="ledger">
                <tr>
                    <th style="width:48px;">No</th>
                    <th>Layanan</th>
                    <th>Student</th>
                    <th>Tanggal Booking</th>
                    <th>Status</th>
                    <th>Aksi</th>
                </tr>
                <% if (bookings.length === 0) { %>
                    <tr class="empty-row"><td colspan="6">Belum ada booking untuk layanan kamu.</td></tr>
                <% } %>
                <% bookings.forEach((el, i) => { %>
                <tr>
                    <td class="mono"><%= i + 1 %></td>
                    <td><%= el.Service ? el.Service.name : '-' %></td>
                    <td><%= el.Student ? el.Student.username : '-' %></td>
                    <td class="mono"><%= new Date(el.bookingDate).toLocaleDateString('id-ID') %></td>
                    <td><span class="badge <%= statusColor(el.status) %>"><%= el.status %></span></td>
                    <td>
                        <% if (el.status === 'pending') { %>
                            <form action="/tutor/bookings/<%= el.id %>/status" method="post">
                                <input type="hidden" name="status" value="confirmed">
                                <button class="btn btn-sm" type="submit">Konfirmasi</button>
                            </form>
                        <% } else if (el.status === 'confirmed') { %>
                            <form action="/tutor/bookings/<%= el.id %>/status" method="post">
                                <input type="hidden" name="status" value="completed">
                                <button class="btn btn-sm" type="submit">Selesaikan</button>
                            </form>
                        <% } else { %>
                            -
                        <% } %>
                    </td>
                </tr>
                <% }) %>
            </table>
        </div>
    </div>
</body>
</html>
