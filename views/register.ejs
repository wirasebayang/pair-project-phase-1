<!DOCTYPE html>
<html lang="id">
<head>
    <%- include('partials/head', { title: 'Daftar' }) %>
</head>
<body>
    <div class="container">
        <div class="card card-narrow">
            <div class="hero-eyebrow">OnlineCourse</div>
            <h1>Buat Akun</h1>
            <p>Daftar sebagai student untuk ikut les, atau sebagai tutor untuk membuka layanan les.</p>

            <% if (typeof error !== 'undefined') { %>
                <div class="alert alert-error"><%= error %></div>
            <% } %>

            <% if (typeof errors !== 'undefined') { %>
                <div class="alert alert-error">
                    <% errors.forEach(error => { %>
                        <div><%= error %></div>
                    <% }) %>
                </div>
            <% } %>

            <form action="/register" method="post">
                <div class="field">
                    <label>Username</label>
                    <input type="text" name="username" autocomplete="username" value="<%= locals.old ? old.username : '' %>">
                </div>
                <div class="field">
                    <label>E-mail</label>
                    <input type="text" name="email" autocomplete="email" value="<%= locals.old ? old.email : '' %>">
                </div>
                <div class="field">
                    <label>Password</label>
                    <input type="password" name="password" autocomplete="new-password">
                </div>
                <div class="field">
                    <label>Daftar sebagai</label>
                    <% let role = ['tutor', 'student'] %>
                    <select name="role">
                        <option disabled <%= locals.old && old.role ? '' : 'selected' %>>--- pilih role ---</option>
                        <% role.forEach(el => { %>
                            <option value="<%= el %>" <%= locals.old && old.role === el ? 'selected' : '' %>><%= el %></option>
                        <% }) %>
                    </select>
                </div>

                <div class="form-actions">
                    <button class="btn" type="submit">Daftar</button>
                    <a href="/">Batal</a>
                </div>
            </form>
        </div>
    </div>
</body>
</html>
